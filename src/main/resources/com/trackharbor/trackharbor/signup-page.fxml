<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.geometry.Insets?>

<AnchorPane
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.trackharbor.trackharbor.controllers.SignUpPageController"
        styleClass="root-pane"
        stylesheets="@styles/login-page-styles.css"
        prefWidth="600"
        prefHeight="480">

    <VBox
            styleClass="card"
            AnchorPane.topAnchor="60"
            AnchorPane.bottomAnchor="60"
            AnchorPane.leftAnchor="100"
            AnchorPane.rightAnchor="100"
            spacing="0">

        <Label text="Create Account" styleClass="title-label"/>

        <VBox styleClass="field-group" spacing="6">
            <Label text="First Name:" styleClass="field-label"/>
            <TextField fx:id="firstNameField" styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-group" spacing="6">
            <Label text="Last Name:" styleClass="field-label"/>
            <TextField fx:id="lastNameField" styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-group" spacing="6">
            <Label text="Email Address:" styleClass="field-label"/>
            <TextField fx:id="emailField" styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-group" spacing="6">
            <Label text="Password:" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" styleClass="input-field"/>
        </VBox>

        <Button
                fx:id="submitButton"
                text="Sign Up"
                styleClass="submit-button"
                onAction="#handleSignUp"/>

        <HBox styleClass="signup-row" alignment="CENTER">
            <Label text="Already have an account? Click " styleClass="signup-label"/>
            <Hyperlink
                    fx:id="loginLink"
                    text="here"
                    styleClass="signup-link"
                    onAction="#handleLogin"/>
        </HBox>

    </VBox>
</AnchorPane>