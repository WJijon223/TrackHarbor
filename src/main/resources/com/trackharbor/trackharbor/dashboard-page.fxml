<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.control.ScrollPane?>
<AnchorPane fx:id="rootPane"
            stylesheets="@styles/dashboard-page-styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trackharbor.trackharbor.controllers.DashboardPageController">

    <children>

        <!-- Top Menu Bar -->
        <MenuBar fx:id="menuBar" styleClass="menu-bar-custom">
            <menus>
                <Menu text="Dashboard"/>
                <Menu text="Table"/>
                <Menu text="Notes"/>
                <Menu text="Logout"/>
            </menus>
        </MenuBar>

        <!-- Main horizontal layout -->
        <HBox spacing="40"
              AnchorPane.topAnchor="80"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="320"
              AnchorPane.bottomAnchor="20">


        <!-- Legend (Left Side) -->
            <VBox fx:id="legendBox"
                  prefWidth="220"
                  HBox.hgrow="NEVER"
                  spacing="20"
                  styleClass="legend-box">

                <HBox spacing="10">
                    <Circle radius="8" fill="#FF69B4" stroke="black" strokeWidth="1.5"/>
                    <Label text="No response"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#800080" stroke="black" strokeWidth="1.5"/>
                    <Label text="2nd Interview"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#32CD32" stroke="black" strokeWidth="1.5"/>
                    <Label text="Waiting"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#FF0000" stroke="black" strokeWidth="1.5"/>
                    <Label text="Rejected"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#0000FF" stroke="black" strokeWidth="1.5"/>
                    <Label text="Email Response"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#000000" stroke="black" strokeWidth="1.5"/>
                    <Label text="Will Not Accept"/>
                </HBox>

                <HBox spacing="10">
                    <Circle radius="8" fill="#FFD700" stroke="black" strokeWidth="1.5"/>
                    <Label text="Job Offered"/>
                </HBox>

            </VBox>

            <!-- Chart Container (Center) -->
            <StackPane fx:id="chartContainer"
                       HBox.hgrow="ALWAYS"
                        styleClass="chart-custom">

                <PieChart fx:id="pieChart"
                          prefWidth="400"
                          prefHeight="400"
                          maxWidth="Infinity"
                          maxHeight="Infinity"
                          labelsVisible="false"
                          legendVisible="false"/>

                <Circle fx:id="donutHole"
                        fill="white"
                        stroke="lightgray"
                        strokeWidth="2"
                        radius="90"/>
            </StackPane>

        </HBox>

        <!-- Slide-in Details Panel -->
        <VBox fx:id="detailsPanel"
              prefWidth="300"
              spacing="20"
              styleClass="details-panel"
              AnchorPane.topAnchor="70"
              AnchorPane.bottomAnchor="20"
              AnchorPane.rightAnchor="0"
              translateX="300">
            <VBox spacing="5" style="-fx-padding: 10 15 0 15;">
            <Label fx:id="detailsTitle" styleClass="details-title" text="Details"/>
            <Label fx:id="detailsCount" styleClass="details-count" text="Count: 0"/>
            </VBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox fx:id="detailsList" spacing="10" style="-fx-padding: 10 15 10 15;"/>
            </ScrollPane>

            <!-- Next & Back Buttons -->
            <HBox alignment="center" spacing="10" style="-fx-padding: 10;">
                <Button fx:id="backButton"
                        text="Back"
                        style="-fx-font-size: 14px; -fx-background-radius: 8;"/>
                <Button fx:id="nextButton"
                        text="Next"
                        style="-fx-font-size: 14px; -fx-background-radius: 8;"/>
            </HBox>

        </VBox>




    </children>
</AnchorPane>
