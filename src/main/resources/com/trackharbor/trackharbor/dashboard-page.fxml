<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane fx:id="rootPane" stylesheets="@styles/dashboard-page-styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.trackharbor.trackharbor.controllers.DashboardPageController">

    <children>

        <!-- Top Menu Bar -->
        <HBox styleClass="menu-bar-custom" spacing="4" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <Button styleClass="menu-nav-button" text="Dashboard" />
            <Button styleClass="menu-nav-button" text="Table" onAction="#handleTableNav" />
            <Button styleClass="menu-nav-button" text="Notes" onAction="#handleNotesNav" />
            <Button styleClass="menu-nav-button" text="Logout" onAction="#handleLogout" />
        </HBox>

        <!-- Main horizontal layout -->
        <HBox spacing="40" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="320" AnchorPane.topAnchor="80">


        <!-- Legend (Left Side) -->
            <VBox fx:id="legendBox" prefWidth="220" spacing="20" styleClass="legend-box" HBox.hgrow="NEVER">

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#FF69B4" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="Interview" />
                </HBox>

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#800080" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="OA" />
                </HBox>

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#32CD32" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="Rejected" />
                </HBox>

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#FF0000" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="Waiting" />
                </HBox>

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#0000FF" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="Accepted" />
                </HBox>

                <HBox spacing="10" styleClass="legend-row">
                    <Circle fill="#FFD700" radius="8" stroke="black" strokeWidth="1.5" />
                    <Label text="Other" />
                </HBox>

            </VBox>

            <!-- Chart Container (Center) -->
            <StackPane fx:id="chartContainer" styleClass="chart-custom" HBox.hgrow="ALWAYS">

                <PieChart fx:id="pieChart" labelsVisible="false" legendVisible="false" maxHeight="Infinity" maxWidth="Infinity" prefHeight="400" prefWidth="400" />

                <Circle fx:id="donutHole" fill="white" radius="90" stroke="lightgray" strokeWidth="2" />
            </StackPane>

        </HBox>

        <!-- Slide-in Details Panel -->
        <VBox fx:id="detailsPanel" prefWidth="300" spacing="20" styleClass="details-panel" translateX="300" AnchorPane.bottomAnchor="20" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="70">
            <VBox spacing="5" styleClass="details-header">
            <Label fx:id="detailsTitle" styleClass="details-title" text="Details" />
            <Label fx:id="detailsCount" styleClass="details-count" text="Count: 0" />
            </VBox>
            <ScrollPane fitToWidth="true" styleClass="details-scroll">
                <VBox fx:id="detailsList" spacing="10" style="-fx-padding: 10 15 10 15;" />
            </ScrollPane>

            <!-- Next & Back Buttons -->
            <HBox alignment="center" spacing="10" styleClass="details-nav">
                <Button fx:id="backButton" styleClass="details-nav-button" text="Back" />
                <Button fx:id="nextButton" styleClass="details-nav-button" text="Next" />
            </HBox>

        </VBox>




    </children>
</AnchorPane>
