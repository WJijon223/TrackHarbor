<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="modalRoot"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.trackharbor.trackharbor.controllers.NoteModalController"
           prefHeight="620.0"
           prefWidth="680.0"
           stylesheets="@styles/note-modal-styles.css"
           styleClass="modal-overlay">

    <VBox maxWidth="640.0" prefWidth="640.0" styleClass="modal-card">

        <!--header-->
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="modal-header">
            <Label text="Notes" styleClass="modal-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#handleClose"
                    styleClass="close-btn" text="✕"/>
        </HBox>

        <Region styleClass="header-accent"/>

        <!-- body -->
        <VBox spacing="16.0" styleClass="modal-body" VBox.vgrow="ALWAYS">

            <!-- company row — populated dynamically by initForPosition() -->
            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="company-row">
                <StackPane styleClass="company-logo-badge">
                    <Label fx:id="companyInitialsLabel" text="?" styleClass="company-logo-mark"/>
                </StackPane>
                <VBox spacing="3.0">
                    <Label fx:id="companyNameLabel"  text="—" styleClass="company-name"/>
                    <Label fx:id="companyStatusLabel" text="—" styleClass="company-role"/>
                    <Label fx:id="companyMetaLabel"  text="—" styleClass="company-meta"/>
                </VBox>
            </HBox>

            <!-- ── notes list section ── -->
            <VBox spacing="8.0">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Interview Notes" styleClass="modal-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="noteCountLabel" text="" styleClass="company-meta"/>
                </HBox>

                <!-- scrollable list — note rows injected here by controller -->
                <ScrollPane fx:id="notesScrollPane"
                            fitToWidth="true"
                            prefHeight="220.0"
                            styleClass="notes-scroll-pane">
                    <VBox fx:id="notesListContainer" styleClass="notes-list" spacing="8">
                        <VBox.margin><Insets top="2" bottom="2"/></VBox.margin>
                    </VBox>
                </ScrollPane>

                <!-- add new note row -->
                <VBox styleClass="content-panel" spacing="8">
                    <TextArea fx:id="newNoteArea"
                              promptText="Write a new note…"
                              prefRowCount="3"
                              wrapText="true"
                              styleClass="notes-area"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="addNoteButton"
                                text="Add Note"
                                onAction="#handleAddNote"
                                styleClass="edit-btn"/>
                    </HBox>
                </VBox>
            </VBox>

            <!--ai tips section -->
            <VBox spacing="10.0">
                <Label text="AI Tips" styleClass="modal-section-title"/>
                <VBox spacing="12.0" styleClass="content-panel">
                    <TextArea fx:id="aiTipsArea"
                              editable="false"
                              focusTraversable="false"
                              prefRowCount="4"
                              styleClass="notes-area ai-tips-area"
                              wrapText="true"/>
                    <HBox alignment="CENTER">
                        <Button mnemonicParsing="false"
                                fx:id="generateTipsButton"
                                onAction="#handleGenerateTips"
                                styleClass="generate-btn"
                                text="Generate Tips"/>
                    </HBox>
                </VBox>
            </VBox>

        </VBox>

        <!-- footer -->
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="modal-footer">
            <Button mnemonicParsing="false"
                    onAction="#handleClose"
                    styleClass="secondary-btn"
                    text="Close"/>
        </HBox>

    </VBox>

    <StackPane.margin>
        <Insets bottom="28.0" left="20.0" right="20.0" top="28.0"/>
    </StackPane.margin>
</StackPane>
