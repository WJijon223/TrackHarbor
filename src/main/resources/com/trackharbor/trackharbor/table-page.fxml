<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.Group?>
<?import javafx.scene.transform.Scale?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.trackharbor.trackharbor.controllers.TablePageController"
           prefHeight="700.0" prefWidth="1100.0"
           style="-fx-background-color: #f0ebff;"
           stylesheets="@styles/table-page-styles.css">

    <children>

        <VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="1100.0" spacing="20.0">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Pane prefHeight="54.0" prefWidth="54.0" style="-fx-background-color: #f3e8ff; -fx-background-radius: 14;">
                                    <children>
                                        <Group layoutX="10.0" layoutY="12.0">
                                            <transforms>
                                                <Scale x="0.88" y="0.88" pivotX="0" pivotY="0"/>
                                            </transforms>
                                            <children>
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M25.522 3.49272L10.3069 3.42594C9.41014 3.42201 8.54858 3.77446 7.91171 4.40576C7.27484 5.03706 6.91484 5.8955 6.91091 6.79223L6.79219 33.8413C6.78826 34.738 7.14071 35.5996 7.77201 36.2365C8.40331 36.8733 9.26175 37.2333 10.1585 37.2373L30.4453 37.3263C31.342 37.3302 32.2036 36.9778 32.8404 36.3465C33.4773 35.7152 33.8373 34.8567 33.8412 33.96L33.9377 11.9826L25.522 3.49272Z" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.832 3.48535L23.8023 10.2476C23.7984 11.1443 24.1508 12.0059 24.7821 12.6428C25.4134 13.2797 26.2719 13.6397 27.1686 13.6436L33.9309 13.6733" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M13.6067 22.0376L16.9878 22.0524" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.7504 22.0821L27.1315 22.097" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M13.577 28.8L16.9581 28.8149" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.7207 28.8445L27.1018 28.8594" />
                                            </children>
                                        </Group>
                                    </children>
                                </Pane>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="TrackHarbor" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                                        <Label text="Keep track of your SWE applications in one place" style="-fx-font-size: 14; -fx-text-fill: #9810FA;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" text="+ New Application"
                                style="-fx-background-color: #6E11B0; -fx-background-radius: 9999; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 13 30; -fx-text-fill: #ffffff; -fx-cursor: hand;" />
                    </children>
                    <padding>
                        <Insets left="28.0" right="28.0" top="16.0" bottom="16.0" />
                    </padding>
                </HBox>

                <VBox VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 16, 0, 0, 4);">
                    <children>
                        <TableView fx:id="applicationsTable" editable="false"
                                   prefHeight="560.0" prefWidth="1044.0"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: #f3f4f6;">
                            <columns>
                                <TableColumn fx:id="nameColumn" prefWidth="260.0" text="Name"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                                <TableColumn fx:id="linkColumn" prefWidth="280.0" text="Link"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                                <TableColumn fx:id="appliedColumn" prefWidth="90.0" text="Applied"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                                <TableColumn fx:id="dateColumn" prefWidth="120.0" text="Date"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                                <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                                <TableColumn fx:id="actionsColumn" prefWidth="100.0" text="Actions"
                                             style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #59168B;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
                    </padding>
                </VBox>

            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>

        <VBox alignment="CENTER" prefHeight="700.0" prefWidth="1100.0"
              style="-fx-background-color: rgba(0,0,0,0.45);" visible="false">
            <children>
                <VBox maxWidth="500.0" spacing="24.0"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 30, 0, 0, 10);">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                            <children>
                                <Pane prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #f3e8ff; -fx-background-radius: 12;">
                                    <children>
                                        <Group layoutX="8.0" layoutY="8.0">
                                            <transforms>
                                                <Scale x="0.82" y="0.82" pivotX="0" pivotY="0"/>
                                            </transforms>
                                            <children>
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M25.522 3.49272L10.3069 3.42594C9.41014 3.42201 8.54858 3.77446 7.91171 4.40576C7.27484 5.03706 6.91484 5.8955 6.91091 6.79223L6.79219 33.8413C6.78826 34.738 7.14071 35.5996 7.77201 36.2365C8.40331 36.8733 9.26175 37.2333 10.1585 37.2373L30.4453 37.3263C31.342 37.3302 32.2036 36.9778 32.8404 36.3465C33.4773 35.7152 33.8373 34.8567 33.8412 33.96L33.9377 11.9826L25.522 3.49272Z" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.832 3.48535L23.8023 10.2476C23.7984 11.1443 24.1508 12.0059 24.7821 12.6428C25.4134 13.2797 26.2719 13.6397 27.1686 13.6436L33.9309 13.6733" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M13.6067 22.0376L16.9878 22.0524" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.7504 22.0821L27.1315 22.097" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M13.577 28.8L16.9581 28.8149" />
                                                <SVGPath fill="transparent" stroke="#6E11B0" strokeWidth="3.38" content="M23.7207 28.8445L27.1018 28.8594" />
                                            </children>
                                        </Group>
                                    </children>
                                </Pane>
                                <Label text="New Application"
                                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                            </children>
                        </HBox>

                        <VBox spacing="16.0">
                            <children>
                                <VBox spacing="6.0">
                                    <Label text="Company Name"
                                           style="-fx-text-fill: #59168B; -fx-font-weight: bold; -fx-font-size: 13;" />
                                    <TextField promptText="e.g. Capital One"
                                               style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-radius: 10;" />
                                </VBox>
                                <VBox spacing="6.0">
                                    <Label text="Position"
                                           style="-fx-text-fill: #59168B; -fx-font-weight: bold; -fx-font-size: 13;" />
                                    <TextField promptText="e.g. SWE Internship"
                                               style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-radius: 10;" />
                                </VBox>
                                <VBox spacing="6.0">
                                    <Label text="Link"
                                           style="-fx-text-fill: #59168B; -fx-font-weight: bold; -fx-font-size: 13;" />
                                    <TextField promptText="https://"
                                               style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-radius: 10;" />
                                </VBox>
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <Label text="Date Applied"
                                                   style="-fx-text-fill: #59168B; -fx-font-weight: bold; -fx-font-size: 13;" />
                                            <TextField promptText="MM/DD/YYYY"
                                                       style="-fx-background-radius: 10; -fx-padding: 10; -fx-border-color: #e5e7eb; -fx-border-radius: 10;" />
                                        </VBox>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <Label text="Status"
                                                   style="-fx-text-fill: #59168B; -fx-font-weight: bold; -fx-font-size: 13;" />
                                            <ComboBox promptText="Select status" maxWidth="Infinity"
                                                      style="-fx-background-radius: 10;">
                                                <items>
                                                    <FXCollections fx:factory="observableArrayList">
                                                        <String fx:value="Rejected" />
                                                        <String fx:value="Waiting" />
                                                        <String fx:value="Interview" />
                                                    </FXCollections>
                                                </items>
                                            </ComboBox>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" text="Cancel"
                                        style="-fx-background-color: #f3f4f6; -fx-text-fill: #4A5565; -fx-background-radius: 9999; -fx-padding: 11 28; -fx-font-size: 14;" />
                                <Button mnemonicParsing="false" text="Add Application"
                                        style="-fx-background-color: #6E11B0; -fx-text-fill: #ffffff; -fx-background-radius: 9999; -fx-padding: 11 28; -fx-font-size: 14; -fx-font-weight: bold;" />
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </VBox>

    </children>
</StackPane>